{
  "name": "lodestar-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "analyze": "source-map-explorer 'build/assets/*.js'",
    "start": "vite",
    "build": "vite build --mode ${NODE_ENV:-production}",
    "preview": "vite preview",
    "test": "jest --passWithNoTests --watchAll=false",
    "typegen": "graphql-codegen",
    "format:organize-imports": "organize-imports-cli ./src/**/*.ts[x]",
    "format:prettier": "prettier --write \"./src/**/*.ts[x]\"",
    "format": "pnpm format:organize-imports && pnpm format:prettier",
    "trans:compile": "babel src --out-dir src/extracted --extensions .ts,.tsx,.js,.jsx --config-file ./.intl.babelrc --ignore '**/*.test.ts,**/*.test.tsx,**/*.spec.ts,**/*.spec.tsx,**/*.d.ts'",
    "trans:extract": "echo 'Messages extracted during compilation'",
    "trans:manage": "node manageTranslations.js",
    "trans:clean": "rm -rf ./src/extracted",
    "trans": "pnpm trans:clean && pnpm trans:compile && pnpm trans:extract && pnpm trans:manage && pnpm trans:clean",
    "prepare": "husky"
  },
